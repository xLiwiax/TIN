
// 1. KLASA KARTY I BAZA DANYCH 

class Card {
    constructor(id, name, strength, row, color, specialAbility = null) {
        this.id = id;
        this.name = name;
        this.baseStrength = strength;
        this.currentStrength = strength;
        this.row = row;
        this.color = color;
        this.specialAbility = specialAbility;
    }

    resetStrength() {
        this.currentStrength = this.baseStrength;
    }
}


let CARD_DATABASE = [];

async function loadCardsData() {
    try {
        const response = await fetch('data/cards.json');
        
        if (!response.ok) {
            throw new Error(`Błąd HTTP ładowania bazy kart! Status: ${response.status}`);
        }
        
        const rawData = await response.json();
        

        CARD_DATABASE = rawData.map(c => new Card(
            c.id, 
            c.name, 
            c.strength, 
            c.row, 
            c.color, 
            c.specialAbility || null
        ));
        
        console.log('Talia kart została pomyślnie wczytana asynchronicznie z pliku JSON!', CARD_DATABASE);
    } catch (error) {
        console.error('Krytyczny błąd podczas ładowania bazy kart:', error);
        alert('Krytyczny błąd gry: Nie można załadować bazy kart z serwera.');
    }
}


// 2. STAN APLIKACJI I ROZGRYWKI

const routingContainer = document.getElementById('routing-container');
const API_URL = 'http://localhost:3000/api/ranking';

let deckPool = [];
let playerHand = [];
let botHand = [];

let playerBoard = { close: [], ranged: [], siege: [] };
let botBoard = { close: [], ranged: [], siege: [] };

let playerWins = 0;
let botWins = 0;
let playerPassed = false;
let botPassed = false;

// Flagi systemowe wymuszające stabilny podział tur i rund
let isBotTurning = false;
let isRoundEnding = false; //anty-konfliktowy 

// Licznik czasu gry
let gameTimerInterval = null;
let gameSeconds = 0;

// Zmienna przechowująca tekst informacyjny o nowej rundzie
let roundMessageBanner = "";


// 3. ZARZĄDZANIE WIDOKAMI (Routing SPA)


function renderMainMenu() {
    clearInterval(gameTimerInterval); // Reset timera przy powrocie do menu
    routingContainer.innerHTML = `
        <div class="menu-container">
            <h2 class="menu-welcome">Witaj w Karczmie, Wiedźminie</h2>
            <div class="menu-buttons">
                <button id="start-game-btn" class="menu-btn">Rozpocznij Grę</button>
                <button id="view-ranking-btn" class="menu-btn btn-secondary">Zobacz Ranking</button>
            </div>
        </div>
    `;

    document.getElementById('start-game-btn').addEventListener('click', startNewGame);
    document.getElementById('view-ranking-btn').addEventListener('click', renderRankingView);
}

function renderRankingView() {
    routingContainer.innerHTML = `
        <div class="ranking-container">
            <h3>🏆 Top 10 Graczy</h3>
            <table class="ranking-table">
                <thead>
                    <tr>
                        <th>Miejsce</th>
                        <th>Gracz</th>
                        <th>Wynik</th>
                        <th>Czas</th>
                    </tr>
                </thead>
                <tbody id="ranking-rows">
                    <tr>
                        <td colspan="4">Ładowanie wyników z bazy...</td>
                    </tr>
                </tbody>
            </table>
            <button id="back-to-menu-btn" class="menu-btn">Powrót do Menu</button>
        </div>
    `;
    document.getElementById('back-to-menu-btn').addEventListener('click', renderMainMenu);
    
    // Asynchroniczne wywołanie pobrania danych z API od razu po wyrenderowaniu tabeli
    loadRankingData();
